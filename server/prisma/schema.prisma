generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TRAINER
  CUSTOMER
}

enum BookingStatus {
  BOOKED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

model User {
  id             String                     @id @default(cuid())
  firstName      String
  lastName       String
  email          String                     @unique
  phone          String?
  passwordHash   String
  role           Role
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  trainerProfile TrainerProfile?
  purchases      Purchase[]
  bookings       Booking[]                  @relation("CustomerBookings")
  refreshTokens  RefreshToken[]
}

model TrainerProfile {
  id                 String                    @id @default(cuid())
  userId             String                    @unique
  headline           String
  bio                String
  specialties        String
  yearsExperience    Int
  imageUrl           String
  isActive           Boolean                   @default(true)
  user               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  blockAssignments   TrainerBlockAssignment[]
  customAvailabilities TrainerCustomAvailability[]
  unavailableSlots   TrainerUnavailableSlot[]
  trainerBookings    Booking[]                 @relation("TrainerBookings")
}

model TrainingPackage {
  id               String      @id @default(cuid())
  title            String
  description      String
  sessionCount     Int
  durationMinutes  Int
  price            Float
  featured         Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  purchases        Purchase[]
}

model Purchase {
  id               String         @id @default(cuid())
  customerId       String
  packageId        String
  totalSessions    Int
  remainingSessions Int
  amount           Float
  paymentStatus    PaymentStatus
  paymentReference String
  createdAt        DateTime       @default(now())
  customer         User           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  trainingPackage  TrainingPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  bookings         Booking[]
}

model Booking {
  id               String        @id @default(cuid())
  trainerId        String
  customerId       String
  purchaseId       String
  startAt          DateTime
  endAt            DateTime
  notes            String?
  status           BookingStatus @default(BOOKED)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  trainer          TrainerProfile @relation("TrainerBookings", fields: [trainerId], references: [id], onDelete: Cascade)
  customer         User          @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  purchase         Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([trainerId, startAt, endAt])
}

model TimeBlock {
  id          String                  @id @default(cuid())
  name        String
  description String
  daysOfWeek  String
  startTime   String
  endTime     String
  assignments TrainerBlockAssignment[]
}

model TrainerBlockAssignment {
  id          String         @id @default(cuid())
  trainerId   String
  blockId     String
  effectiveFrom DateTime
  effectiveTo DateTime?
  trainer     TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  block       TimeBlock      @relation(fields: [blockId], references: [id], onDelete: Cascade)
}

model TrainerCustomAvailability {
  id          String         @id @default(cuid())
  trainerId   String
  date        DateTime
  startTime   String
  endTime     String
  label       String?
  trainer     TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
}

model TrainerUnavailableSlot {
  id          String         @id @default(cuid())
  trainerId   String
  startAt     DateTime
  endAt       DateTime
  reason      String?
  trainer     TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  targetUserId String?
  action      String
  metadata    String?
  createdAt   DateTime @default(now())
}
